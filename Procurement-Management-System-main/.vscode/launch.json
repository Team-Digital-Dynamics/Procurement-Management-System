{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Spring Boot: PMS",
            "request": "launch",
            "mainClass": "com.digitaldynamics.pms.PmsApplication",
            "cwd": "${workspaceFolder}/pms",
            "env": {
                "SPRING_PROFILES_ACTIVE": "dev"
            },
            "console": "integratedTerminal"
        },
        {
            "type": "java",
            "name": "Attach: PMS Docker",
            "request": "attach",
            "hostName": "localhost",
            "port": 5005
        },
        {
            "type": "java",
            "name": "Spring Boot-PmsApplication<digital-dynamics-pms>",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "com.digitaldynamics.pms.PmsApplication",
            "projectName": "digital-dynamics-pms",
            "args": "",
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}
